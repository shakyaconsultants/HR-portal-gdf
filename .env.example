# MongoDB
MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=trainee_portal

# Auth — use a long random string (32+ characters)
JWT_SECRET=change_this_to_a_long_random_secret_value

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP (required for offer letter / ID card email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASS=your_app_password
SMTP_FROM=your-email@company.com

# Cloudinary (required for file uploads in production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Onboarding link expiry (days)
ONBOARDING_TOKEN_TTL_DAYS=3

# User seeding — npm run seed:users deletes all users then seeds fresh (never commit real passwords)
SEED_USERS_ENABLED=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin User
SEED_HR_EMAIL=
SEED_HR_PASSWORD=
SEED_HR_NAME=HR User
SEED_TRAINER_EMAIL=
SEED_TRAINER_PASSWORD=
SEED_TRAINER_NAME=Trainer User
